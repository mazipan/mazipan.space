---
import BaseHead from '@/components/BaseHead.astro';
import Footer from '@/components/Footer.astro';
import Header from '@/components/Header.astro';
import Breakpoints from '@/components/utils/breakpoints.astro';

import type { BaseHeadProps } from '@/components/BaseHead.astro';

export interface BaseProps extends BaseHeadProps {}

const { metadata } = Astro.props as BaseProps;
---

<html lang="en">
  <BaseHead {metadata} />
  <body
    class="bg-base-100 relative flex min-h-screen min-w-80 flex-col scroll-smooth transition-colors duration-500"
  >
    <Header />
    <div id="app-body" class="app-body relative mt-[65px]">
      <slot />
    </div>
    <Footer />

    <Breakpoints />
  </body>
</html>
