---
interface Stat {
  label: string;
  value: string;
  growth: number;
  color: string; // hex, e.g. '#3b82f6'
  // SVG points "x,y x,y ..." within a 120×50 viewBox (y=0 is top)
  sparkPoints: string;
}

interface Milestone {
  clicks: string;
  period: string;
  date: string;
}

interface Props {
  title?: string;
  period?: string;
  stats: Stat[];
  milestones?: Milestone[];
}

const { title = 'Google Search Console', period = 'Last 7 days', stats, milestones } = Astro.props;

function hexToRgba(hex: string, alpha: number): string {
  const r = parseInt(hex.slice(1, 3), 16);
  const g = parseInt(hex.slice(3, 5), 16);
  const b = parseInt(hex.slice(5, 7), 16);
  return `rgba(${r},${g},${b},${alpha})`;
}

function toLinePath(points: string): string {
  const pts = points
    .trim()
    .split(/\s+/)
    .map((p) => p.split(',').map(Number));
  if (!pts.length) return '';
  return pts.reduce((d, [x, y], i) => d + (i === 0 ? `M ${x},${y}` : ` L ${x},${y}`), '');
}

function toAreaPath(points: string): string {
  const pts = points
    .trim()
    .split(/\s+/)
    .map((p) => p.split(',').map(Number));
  if (!pts.length) return '';
  const [[x0]] = pts;
  const [xLast] = pts[pts.length - 1];
  const line = pts.reduce((d, [x, y], i) => d + (i === 0 ? `L ${x},${y}` : ` L ${x},${y}`), '');
  return `M ${x0},50 ${line} L ${xLast},50 Z`;
}
---

<div class="not-prose rounded-box border-base-300 bg-base-200 my-8 overflow-hidden border">
  <!-- Header -->
  <div class="border-base-300 flex items-center justify-between border-b px-5 py-3">
    <div class="flex items-center gap-2">
      <!-- Google logo mark -->
      <svg viewBox="0 0 24 24" class="h-4 w-4 shrink-0" aria-hidden="true">
        <path
          d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
          fill="#4285F4"></path>
        <path
          d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
          fill="#34A853"></path>
        <path
          d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
          fill="#FBBC05"></path>
        <path
          d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
          fill="#EA4335"></path>
      </svg>
      <span class="text-headings text-sm font-semibold">{title}</span>
    </div>
    <span class="bg-base-300 text-captions rounded-full px-2.5 py-0.5 text-xs">{period}</span>
  </div>

  <!-- Stat cards -->
  <div class="divide-base-300 grid grid-cols-1 divide-y sm:grid-cols-2 sm:divide-x sm:divide-y-0">
    {
      stats.map((stat) => (
        <div class="px-5 py-4">
          <p class="text-captions text-sm">{stat.label}</p>
          <div class="mt-1 flex items-baseline justify-between gap-2">
            <p class="text-headings text-3xl font-bold">{stat.value}</p>
            <span
              class={
                stat.growth >= 0
                  ? 'inline-flex items-center gap-0.5 rounded-full bg-green-100 px-2 py-0.5 text-xs font-semibold text-green-700 dark:bg-green-900/30 dark:text-green-400'
                  : 'inline-flex items-center gap-0.5 rounded-full bg-red-100 px-2 py-0.5 text-xs font-semibold text-red-700 dark:bg-red-900/30 dark:text-red-400'
              }
            >
              {stat.growth >= 0 ? '↑' : '↓'}
              {Math.abs(stat.growth)}%
            </span>
          </div>
          <svg
            viewBox="0 0 120 50"
            class="mt-3 h-12 w-full"
            preserveAspectRatio="none"
            aria-hidden="true"
          >
            <path d={toAreaPath(stat.sparkPoints)} fill={hexToRgba(stat.color, 0.15)} />
            <path
              d={toLinePath(stat.sparkPoints)}
              fill="none"
              stroke={stat.color}
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
        </div>
      ))
    }
  </div>

  <!-- Milestones -->
  {
    milestones && milestones.length > 0 && (
      <div class="border-base-300 border-t px-5 py-4">
        <p class="text-captions mb-3 text-xs font-semibold tracking-wider uppercase">Milestones</p>
        <div class="flex flex-col gap-3">
          {milestones.map((m) => (
            <div class="flex items-center gap-3">
              <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-full bg-amber-400/20">
                <span class="text-xs font-bold text-amber-600 dark:text-amber-400">{m.clicks}</span>
              </div>
              <div class="min-w-0 flex-1">
                <p class="text-headings text-sm font-medium">
                  {m.clicks} clicks from Google Search
                </p>
                <p class="text-captions text-xs">
                  in {m.period} &middot; {m.date}
                </p>
              </div>
              <svg
                class="h-5 w-5 shrink-0 text-green-500"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                  clip-rule="evenodd"
                />
              </svg>
            </div>
          ))}
        </div>
      </div>
    )
  }
</div>
