{
  "name": "mazipan.space",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "astro": "astro",
    "build:with-version": "APP_VERSION=$(npm pkg get version | xargs) APP_DEPLOY_AT=$(date +'%Y-%m-%d %H:%M:%S') astro build",
    "build": "pnpm generate && pnpm build:with-version",
    "check-types": "tsc --noEmit --pretty",
    "clean": "rm -rf node_modules pnpm-lock.yaml",
    "dev": "APP_VERSION=$(npm pkg get version | xargs) APP_DEPLOY_AT=$(date +'%Y-%m-%d %H:%M:%S') astro dev",
    "format": "prettier --write .",
    "lint": "eslint src",
    "preview": "astro preview",
    "start": "serve ./dist",
    "generate": "node ./scripts/copy-talks.js && node ./scripts/copy-awesome-sde.js",
    "sync": "astro sync"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^6.0.1",
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/react": "^5.0.7",
    "@astrojs/sitemap": "^3.7.3",
    "@expressive-code/core": "^0.42.0",
    "@expressive-code/plugin-collapsible-sections": "^0.42.0",
    "@expressive-code/plugin-line-numbers": "^0.42.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/dela-gothic-one": "^5.2.7",
    "astro": "6.4.2",
    "astro-embed": "^0.13.0",
    "astro-expressive-code": "^0.42.0",
    "astro-icon": "^1.1.5",
    "astro-remote": "^0.3.4",
    "astro-social-share": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.3.0",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "expressive-code-color-chips": "^0.1.4",
    "feed": "^5.2.1",
    "giscus": "^1.6.0",
    "github-slugger": "^2.0.0",
    "mdast-util-to-string": "^4.0.0",
    "object-treeify": "^5.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reading-time": "^1.5.0",
    "rehype-code-group": "^0.3.1",
    "sharp": "0.34.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.1",
    "tailwind-clip-path": "^1.0.0",
    "tailwind-merge": "^3.6.0",
    "usehooks-ts": "^3.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@iconify-json/tabler": "^1.2.35",
    "@types/mdast": "^4.0.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "eslint": "10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-mdx": "^3.8.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-mdx": "^3.7.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "satori": "^0.26.0",
    "satori-html": "^0.3.2",
    "serve": "^14.2.6",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=24.0.0"
  }
}
