{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "astro/tsconfigs/strict",
  "display": "Default",
  "esModuleInterop": true,
  "compilerOptions": {
    "allowJs": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "noEmit": true,
    "skipLibCheck": true,
    "paths": {
      "@/assets/*": ["./src/assets/*"],
      "@/components/*": ["./src/components/*"],
      "@/constants/*": ["./src/constants/*"],
      "@/content/*": ["./src/content/*"],
      "@/layouts/*": ["./src/layouts/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/libs/*": ["./src/libs/*"],
      "@/pages/*": ["./src/pages/*"],
      "@/schemas/*": ["./src/schemas/*"],
      "@/styles/*": ["./src/styles/*"],
      "@/types/*": ["./src/types/*"],
      "@/utils/*": ["./src/utils/*"],
      "@/config/*": ["./src/config/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.astro"],
  "exclude": ["dist", "docs", "node_modules"]
}
